{
  "name": "chatapp-backend",
  "version": "1.0.0",
  "description": "API Gateway and Mastra Agent Service for Chat App POC",
  "main": "dist/api.js",
  "scripts": {
    "build": "tsc",
    "start:api": "ts-node src/api.ts",
    "start:mastra": "ts-node src/mastra.ts",
    "start": "concurrently \"npm run start:api\" \"npm run start:mastra\""
  },
  "dependencies": {
    "@mastra/core": "^0.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "fuse.js": "^7.4.2",
    "ws": "^8.17.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.2",
    "@types/ws": "^8.5.10",
    "concurrently": "^8.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
